<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Progress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:progress="33"
                android:max="100"
                android:progressTint="@color/brand_purple"
                android:backgroundTint="@color/progress_bg" />

            <TextView
                android:id="@+id/tvStep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="@string/profile_step_1_3"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/profile_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/profile_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Photo zone (stylée) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            android:foregroundGravity="center">

            <!-- Grand cercle gris -->
            <View
                android:id="@+id/photoCircleBg"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_light" />

            <!-- Icône caméra au centre -->
            <ImageView
                android:id="@+id/imgPhoto"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_camera_outline"
                android:contentDescription="@string/cd_profile_photo"
                android:tint="@color/icon_muted" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnAddPhoto"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:layout_marginStart="60dp"
                android:layout_marginTop="50dp"
                android:contentDescription="@string/cd_add_photo"
                android:src="@drawable/ic_camera_solid"
                app:backgroundTint="@color/brand_pink"
                app:tint="@android:color/white"
                />

            <!-- Texte -->
            <TextView
                android:id="@+id/tvAddPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="10dp"
                android:text="@string/profile_add_photo"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </FrameLayout>

        <!-- Pseudo -->
        <TextView
            android:id="@+id/lblPseudo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/profile_label_pseudo_required"
            android:textColor="@color/brand_purple"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPseudo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/profile_hint_pseudo"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:maxLength="10"
            android:inputType="textPersonName"
            android:autofillHints="username"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvPseudoHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_pseudo_help"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="10dp" />

        <!-- Birthday -->
        <TextView
            android:id="@+id/lblBirthday"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_label_birthday_required"
            android:textColor="@color/brand_purple"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etBirthday"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/profile_hint_birthday"
            android:background="@android:drawable/editbox_background"
            android:padding="12dp"
            android:inputType="text"
            android:autofillHints="birthDate"
            android:textColor="@color/text_primary" />

        <!-- Gender -->
        <TextView
            android:id="@+id/lblGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_label_gender_required"
            android:textColor="@color/brand_purple"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbFemme"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/gender_female"
                android:padding="12dp" />

            <RadioButton
                android:id="@+id/rbHomme"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/gender_male"
                android:padding="12dp" />

            <RadioButton
                android:id="@+id/rbAutre"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/gender_other"
                android:padding="12dp" />
        </RadioGroup>

        <!-- Description -->
        <TextView
            android:id="@+id/lblDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/profile_label_description_optional"
            android:textColor="@color/brand_purple"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDesc"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@android:drawable/editbox_background"
            android:hint="@string/profile_hint_description"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:maxLength="300"
            android:autofillHints="postalAddress"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/profile_desc_counter_default"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="end"
            android:layout_marginTop="4dp" />

        <!-- Continue -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="18dp"
            android:text="@string/profile_continue"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/brand_purple" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="18dp" />
    </LinearLayout>
</ScrollView>