<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Matchme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/montserrat</item>

        <item name="fontFamily">@font/montserrat</item>

        <item name="colorPrimary">#000000</item>
    </style>

    <style name="Theme.Matchme" parent="Base.Theme.Matchme" />

    <style name="SettingsRowStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="android:background">@drawable/bg_settings_item</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">20dp</item>
    </style>

    <style name="SettingsTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#1A202C</item>
        <item name="android:textSize">16sp</item>
    </style>

</resources>